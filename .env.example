# Copy file này thành .env và điền giá trị thực
# cp .env.example .env

# ── Bắt buộc ──────────────────────────────────────
# OpenAI API key (dùng cho model access)
OPENAI_API_KEY=sk-...

# ── Tùy chọn: Telegram ────────────────────────────
# Lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=

# ── Tùy chọn: Discord ─────────────────────────────
# Lấy từ Discord Developer Portal
DISCORD_BOT_TOKEN=
